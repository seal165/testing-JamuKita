# Environment variables for Go Rent application
# Database connection string
# Ensure to replace 'root' with your actual database user if different
# and 'go_rent' with your actual database name.
DATABASE_URL="mysql://root@localhost/go_rent"

# JWT secret key for signing tokens
JWT_SECRET="your_jwt_secret_key"
# Replace 'your_jwt_secret_key' with a strong secret key for JWT signing.
# This key should be kept secret and not shared publicly.
# Port on which the application will run
PORT=8080
# Replace '8080' with the desired port number if needed.
# Environment for the application
NODE_ENV="development"
# Set to 'production' for production environment or 'development' for development environment.
APP_URL="http://localhost:8080"

# AWS S3 Configuration for image uploads
