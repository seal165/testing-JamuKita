# Test Environment Configuration
# Copy this file to .env.test and configure for your test environment

# Database URL for testing
# Option 1: SQLite in-memory (for CI/CD, no MySQL needed)
DATABASE_URL="file::memory:?socket_timeout=10&connection_limit=1"

# Option 2: SQLite file-based (persists during test session)
# DATABASE_URL="file:./test.db"

# Option 3: MySQL (for local testing with real MySQL)
# DATABASE_URL="mysql://root:password@localhost:3306/jamukita_test"

# JWT Secret for testing
JWT_SECRET="test_jwt_secret_key_for_testing_only_change_this"

# Server Port for testing
PORT=3001

# Node Environment
NODE_ENV=test
